# Environment Variables for FoodHub

# API Configuration
VITE_API_URL=http://localhost:3000/api

# App Configuration
VITE_APP_NAME=FoodHub
VITE_APP_LOGO_URL=/logo.svg

# Feature Flags
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_ANALYTICS=false

# Timeouts (in milliseconds)
VITE_API_TIMEOUT=10000
VITE_CART_AUTO_SAVE_DELAY=1000

# Payment Configuration
VITE_PAYMENT_GATEWAY=stripe
VITE_ENABLE_COD=true
VITE_ENABLE_WALLET=true

# Delivery Configuration
VITE_DEFAULT_DELIVERY_FEE=49
VITE_MIN_ORDER_VALUE=100
VITE_MAX_DELIVERY_TIME=60
